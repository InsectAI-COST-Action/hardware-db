{
  "info": {
    "title": "InsectAI hardware form - full version",
    "description": "Welcome! This form is to provide or update for your insect monitoring hardware to the InsectAI hardware database. \\n \\n Already submitted hardware or have a new version? You may also use this form to submit new versions of existing hardware or add/update existing hardware details. If so, please provide your latest deviceID where prompted. \\n\\n Unsure if you have already submitted? If you are unsure what has already been submitted to the database please either 1. check your email for a deviceID 2. access the public database here: ___ or 3. contact the current handler whose details will be available here: ___ providing them with some basic hardware details. \\n\\n "
  },
  "settings": {
    "emailCollectionType": "DO_NOT_COLLECT"
  },
  "sections": [
    {
      "id": "device_id_section",
      "title": "Device ID and version",
      "description": null,
      "questions": [
        {
          "id": "have_deviceID",
          "title": "Do you already have a deviceID for this hardware?",
          "required": true,
          "type": "choice",
          "choiceType": "RADIO",
          "options": [
            "Yes",
            "No"
          ],
          "logic": {
            "Yes": {
              "go_to": "new_device_version"
            },
            "No": {
              "go_to": "basic_info"
            }
          }
        }
      ]
    },
    {
      "id": "new_device_version",
      "title": "New device version",
      "description": "Information about who the device was created by, who is contributing to this entry and who will be responsible in future for queries about and updates to this entry. \\n \\n These may all be the same individual in some cases and there may be co-creators. In the case of multiple individuals separate the names and emails of the creators with ';' (e.g. Alan Turner; Dave Johnson)",
      "questions": [
        {
          "id": "previous_deviceID",
          "title": "Previous deviceID",
          "required": true,
          "type": "text",
          "paragraph": false
        }
      ]
    },
    {
      "id": "basic_info",
      "title": "Basic information",
      "questions": [
        {
          "id": "contact_name",
          "title": "Contact name",
          "required": true,
          "type": "text",
          "paragraph": false
        },
        {
          "id": "contact_email",
          "title": "Contact email",
          "required": true,
          "type": "text",
          "paragraph": false
        },
        {
          "id": "device_name",
          "title": "Device name",
          "required": true,
          "type": "text",
          "paragraph": false
        },
        {
          "id": "device_description",
          "title": "Device description",
          "required": true,
          "type": "text",
          "paragraph": true
        }
      ]
    },
    {
      "id": "fill_in_full_form",
      "title": "Proceed with filling in full form?",
      "description": "Would you like to proceed with filling in the full form? \\n\\n There are 6 sections in total with a total of 70 questions: \\n - Contributor details (7 questions); \\n - Device links (4 questions); \\n - Device details (11 questions); \\n - Component details (27 questions); \\n - Maintenance and repairs (3 questions); \\n - Usage scope (12 questions). \\n\\n  If you would like to stop here, please click 'No' and then Submit on the next page. ",
      "questions": [
        {
          "id": "to_full_form",
          "title": "Proceed with filling in full form?",
          "required": true,
          "type": "choice",
          "choiceType": "RADIO",
          "options": [
            "Yes, take me to the questions",
            "No, I want to submit with just the basic information"
          ],
          "logic": {
            "Yes": {
              "go_to": "contributor_details"
            },
            "No": {
              "go_to": "submit_form"
            }
          }
        }
      ]
    },
    {
      "id": "contributor_details",
      "title": "Contributor details",
      "description": "New version: This section is for providing a distinct new device version. \\n\\n Help: To help decide if your device has entered a new version, the following is an adaption of semantic reasoning (used for software versioning) for electronics/hardware is useful: https://www.maskset.net/blog/2023/02/26/semantic-versioning-for-hardware/ \\n \\n Existing devices: If you want to update an existing device, please use the linked form at the top of this form instead",
      "questions": [
        {
